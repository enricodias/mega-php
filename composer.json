{
    "name": "enricodias/mega",
    "description": "A PHP client for the Mega.nz API.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "mega.nz",
        "mega.co.nz",
        "api-client"
    ],
    "authors": [
        {
            "name": "Enrico Dias",
            "email": "enrico@enricodias.com"
        }
    ],
    "require": {
        "php": "^7.3 || ^8.0",
        "ext-bcmath": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "psr/cache": "^1.0",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/http-factory": "^1.1",
        "php-http/discovery": "^1.20",
        "psr/log": "^1.1 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "guzzlehttp/guzzle": "^7.12",
        "guzzlehttp/psr7": "^2.0"
    },
    "suggest": {
        "guzzlehttp/guzzle": "Required when no PSR-18 HTTP client is provided (auto-discovered at runtime).",
        "monolog/monolog": "A PSR-3 logger implementation to enable request/response logging."
    },
    "autoload": {
        "psr-4": {
            "Mega\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mega\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "platform": {
            "php": "7.3.33"
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
